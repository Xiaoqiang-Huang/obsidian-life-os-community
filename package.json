{
  "name": "obsidian-life-os",
  "version": "0.3.2",
  "description": "A local-first personal life system for Obsidian: diary, tasks, knowledge, memory, and AI-assisted reviews.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "check": "tsc -noEmit -skipLibCheck",
    "test": "npm run check && npm run build"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ai",
    "diary",
    "tasks"
  ],
  "author": "Xiaoqiang Huang",
  "license": "PolyForm-Noncommercial-1.0.0",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5"
  }
}
